{
  "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
  "applicationId": "js.ripple.ssh",
  "version": "1.0.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/resources/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": true,
    "writeToLogFile": true
  },
  "nativeAllowList": [
    "app.*",
    "os.*",
    "storage.*",
    "window.*",
    "extensions.*",
    "filesystem.*",
    "debug.log"
  ],
  "enableExtensions": true,
  "extensions": [
    {
      "id": "js.ripple.ssh",
      "command": "node ${NL_PATH}/extensions/ssh-connector/main.js"
    }
  ],
  "modes": {
    "window": {
      "title": "Ripple SSH",
      "width": 1100,
      "height": 700,
      "minWidth": 800,
      "minHeight": 500,
      "center": true,
      "icon": "/resources/icons/appIcon.png",
      "enableInspector": false,
      "resizable": true,
      "extendUserAgent": true
    }
  },
  "cli": {
    "binaryName": "neutralino",
    "resourcesPath": "/resources/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/resources/js/neutralino.js",
    "binaryVersion": "6.7.0",
    "clientVersion": "6.7.0"
  }
}