{
  "name": "ripple-ssh",
  "version": "1.0.0",
  "description": "Ripple SSH - SSH & SFTP Client built with Neutralino.js",
  "main": "neutralino.config.json",
  "scripts": {
    "prepare": "node scripts/prepare-frontend.js",
    "dev": "pnpm prepare && neu run",
    "build": "pnpm prepare && neu build --embed-resources",
    "package": "node scripts/package.js",
    "clean": "rm -rf dist",
    "update": "neu update"
  },
  "keywords": ["ssh", "sftp", "remote", "terminal"],
  "author": "",
  "license": "MIT",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.2.2",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@neutralinojs/neu": "^11.7.1"
  },
  "dependencies": {
    "ssh2": "^1.17.0",
    "ws": "^8.21.0",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0"
  }
}
